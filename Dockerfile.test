FROM golang:1.25.0-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends rsync openssh-client make gcc git docker.io && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Create directory for Docker socket mount
RUN mkdir -p /var/run

COPY go.mod go.sum /app

RUN go mod download

ENV PICO_SECRET="danger"
# Disable Ryuk cleanup container — it has issues in socket-mount scenarios
ENV TESTCONTAINERS_RYUK_DISABLED="true"

COPY . /app

CMD ["go", "test", "-race", "./..."]
