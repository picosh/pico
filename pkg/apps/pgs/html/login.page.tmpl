{{define "title"}}Password Protected Site{{end}}

{{define "meta"}}
{{end}}

{{define "attrs"}}class="container" style="height: 100vh;"{{end}}

{{define "body"}}
<div class="container flex justify-center">
	<div style="max-width: 450px;" class="mt-4 border py-4 px-4 flex flex-col gap">
  	<h1 class="text-lg">Password protected site</h1>

		<div>The site admin must share the password for this site in order to access it.  Access is then granted for 24 hours.</div>

		{{if .Error}}
  	<div style="color: tomato;">{{.Error}}</div>
  	{{end}}

  	<form method="POST" action="/pgs/login">
  		<input type="hidden" name="project" value="{{.ProjectName}}">
  		<label for="password">Enter password:</label>
      <div class="flex gap">
    		<input type="password" id="password" name="password" placeholder="Password" required autofocus>
    		<button type="submit">Access</button>
      </div>
  	</form>
	</div>
</div>
{{end}}
